{
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "mjml-editor-dev",
    "TenantsCollectionName": "tenants",
    "TemplatesCollectionName": "emailTemplates",
    "UsersCollectionName": "users"
  },
  "Jwt": {
    "Issuer": "MjmlEditor.Api",
    "Audience": "MjmlEditor.Frontend",
    "SigningKey": "dev-signing-key-change-me-1234567890"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}
